<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RotoDex.Mobile.MainPage">

    <ScrollView>
        <Grid RowDefinitions="Auto,*,Auto" Padding="30">
            
            <!-- Header -->
            <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,40,0,0">
                <Image Source="dotnet_bot.png"
                       SemanticProperties.Description="RotoDex Logo"
                       HeightRequest="150"
                       HorizontalOptions="Center" />
                <Label Text="RotoDex Mobile"
                       Style="{StaticResource Headline}"
                       SemanticProperties.HeadingLevel="Level1"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Primary}}" />
                <Label Text="The Ultimate Pokémon Save Editor"
                       Style="{StaticResource SubHeadline}"
                       SemanticProperties.HeadingLevel="Level2"
                       SemanticProperties.Description="Welcome to RotoDex Mobile"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource Gray400}" />
            </VerticalStackLayout>

            <!-- Main Content Area (Save Info or Initial State) -->
            <VerticalStackLayout Grid.Row="1" Spacing="25" VerticalOptions="Center" HorizontalOptions="Center">
                
                <!-- Save Details Card (Hidden by default) -->
                <Border x:Name="SaveDetailsCard" IsVisible="False" BackgroundColor="{AppThemeBinding Light=#EEFFFFFF, Dark=#EE222222}" StrokeShape="RoundRectangle 15" Padding="25" Stroke="{StaticResource Primary}" StrokeThickness="2" WidthRequest="300">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Save Loaded!" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
                        <BoxView HeightRequest="1" Color="{StaticResource Gray400}" Margin="0,5" />
                        
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="5" ColumnSpacing="10">
                            <Label Grid.Row="0" Grid.Column="0" Text="Trainer:" FontAttributes="Bold" />
                            <Label Grid.Row="0" Grid.Column="1" x:Name="TrainerNameLabel" Text="---" />
                            
                            <Label Grid.Row="1" Grid.Column="0" Text="Game:" FontAttributes="Bold" />
                            <Label Grid.Row="1" Grid.Column="1" x:Name="GameVersionLabel" Text="---" />
                            
                            <Label Grid.Row="2" Grid.Column="0" Text="Play Time:" FontAttributes="Bold" />
                            <Label Grid.Row="2" Grid.Column="1" x:Name="PlayTimeLabel" Text="---" />
                        </Grid>
                        
                        <VerticalStackLayout x:Name="SaveActionsPanel" Spacing="15" Margin="0,20,0,0">
                            <Button x:Name="ViewBoxesBtn" Text="View Boxes" Clicked="OnViewBoxesClicked" BackgroundColor="#03DAC6" TextColor="Black" FontAttributes="Bold" CornerRadius="8" Padding="0,15" />
                            <Button x:Name="LegalityCheckBtn" Text="Legality Check" Clicked="OnLegalityCheckClicked" BackgroundColor="#CF6679" TextColor="White" FontAttributes="Bold" CornerRadius="8" Padding="0,15" />
                            <Button x:Name="ExportSaveBtn" Text="Export Save" Clicked="OnExportSaveClicked" BackgroundColor="#6200EE" TextColor="White" FontAttributes="Bold" CornerRadius="8" Padding="0,15" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Status Label -->
                <Label x:Name="StatusLabel" Text="Select a Pokémon save file (.sav or main) from your device to begin." HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="{StaticResource Gray400}" FontSize="14" />
                
                <Button x:Name="OpenSaveBtn"
                        Text="Open Save File"
                        SemanticProperties.Hint="Opens a file picker to select your save"
                        Clicked="OnOpenSaveClicked"
                        HorizontalOptions="Center"
                        WidthRequest="250"
                        HeightRequest="60"
                        CornerRadius="30"
                        FontAttributes="Bold"
                        FontSize="16" />
            </VerticalStackLayout>
            
            <!-- Footer -->
            <Label Grid.Row="2" Text="Powered by Roto.Core" HorizontalOptions="Center" FontSize="12" TextColor="{StaticResource Gray300}" Margin="0,20,0,0" />
            
        </Grid>
    </ScrollView>

</ContentPage>
