<Window x:Class="RotoDex.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RotoDex | Editor" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Icon="RotoDex.png"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header and Menu Bar -->
        <Border Grid.Row="0" Background="{StaticResource BackgroundSecondary}" Padding="15,10,15,10" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Logo & Brand -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,25,0">
                    <Image Source="RotoDex.png" Width="28" Height="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="RotoDex" FontSize="18" FontWeight="ExtraBold" VerticalAlignment="Center" Foreground="#3B82F6"/>
                </StackPanel>

                <!-- Menu Bar -->
                <Menu Background="Transparent" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" DockPanel.Dock="Left">
                    <MenuItem Header="File">
                        <MenuItem Header="Open Save..." Click="OpenFile_Click" Background="{StaticResource BackgroundSecondary}"/>
                        <MenuItem Header="Write Active Save" Click="SaveActiveFile_Click" Background="{StaticResource BackgroundSecondary}"/>
                        <MenuItem Header="Close Active Save" Click="CloseActiveFile_Click" Background="{StaticResource BackgroundSecondary}"/>
                        <Separator Background="{StaticResource BackgroundTertiary}"/>
                        <MenuItem Header="Exit" Click="Exit_Click" Background="{StaticResource BackgroundSecondary}"/>
                    </MenuItem>
                    <MenuItem Header="Edit">
                        <MenuItem Header="Undo" Click="Undo_Click" InputGestureText="Ctrl+Z" Background="{StaticResource BackgroundSecondary}"/>
                        <MenuItem Header="Redo" Click="Redo_Click" InputGestureText="Ctrl+Y" Background="{StaticResource BackgroundSecondary}"/>
                    </MenuItem>
                    <MenuItem Header="Tools">
                        <MenuItem Header="Batch Editor..." Click="OpenBatchEditor_Click" Background="{StaticResource BackgroundSecondary}"/>
                    </MenuItem>
                </Menu>
            </DockPanel>
        </Border>

        <!-- Welcome / Landing Empty State -->
        <Grid x:Name="WelcomePanel" Grid.Row="1" Visibility="Visible">
            <Border Background="{StaticResource BackgroundSecondary}" CornerRadius="12" Margin="30" Padding="40" BorderBrush="#1E293B" BorderThickness="1.5" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="600">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Glowing pulsing logo -->
                    <Border Width="110" Height="110" CornerRadius="55" Background="#0F172A" BorderBrush="#3B82F6" BorderThickness="2" Padding="15" Margin="0,0,0,20">
                        <Image Source="RotoDex.png"/>
                    </Border>
                    
                    <TextBlock Text="Welcome to RotoDex" FontSize="26" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="#F8FAFC" Margin="0,0,0,8"/>
                    <TextBlock Text="An offline, lightning-fast Pokémon save file editor." FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                    
                    <Button Content="Open Pokémon Save File..." Width="220" Height="40" Click="OpenFile_Click" HorizontalAlignment="Center" Cursor="Hand"/>
                    
                    <!-- Drag & drop indicator -->
                    <Border BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="20,12" Margin="0,25,0,0" Background="#0F172A">
                        <TextBlock Text="💡 Tip: Drag and drop save files (.sav or main) directly into this window!" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center" TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tab Control for Multiple Saves -->
        <TabControl x:Name="SaveTabs" Grid.Row="1" Background="{StaticResource BackgroundPrimary}" BorderThickness="0" Margin="10" SelectionChanged="SaveTabs_SelectionChanged" Visibility="Collapsed"/>
        
    </Grid>
</Window>
