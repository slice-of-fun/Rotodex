<UserControl x:Class="RotoDex.Desktop.SaveEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundPrimary}">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar (Box Viewer) -->
        <Border Grid.Column="0" Background="{StaticResource BackgroundSecondary}" CornerRadius="12" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Storage Boxes" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource TextPrimary}"/>
                <ComboBox x:Name="BoxSelector" Grid.Row="1" SelectionChanged="BoxSelector_SelectionChanged" Margin="0,0,0,15" Height="30"/>
                <ListBox x:Name="BoxList" Grid.Row="2" SelectionChanged="BoxList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
            </Grid>
        </Border>

        <!-- Main Editor -->
        <Border Grid.Column="2" Background="{StaticResource BackgroundSecondary}" CornerRadius="12" Padding="25">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Sprite Placeholder -->
                    <Border Grid.Column="0" Width="68" Height="56" Background="{StaticResource BackgroundTertiary}" CornerRadius="8" Margin="0,0,15,0">
                        <TextBlock Text="?" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" Foreground="{StaticResource TextSecondary}"/>
                    </Border>

                    <TextBlock Grid.Column="1" Text="Pokémon Details" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                    
                    <Border x:Name="LegalityBadge" Grid.Column="2" Background="{StaticResource BackgroundTertiary}" CornerRadius="6" Padding="10,5" VerticalAlignment="Center">
                        <TextBlock x:Name="LegalityText" Text="No Pokémon Selected" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                    </Border>
                </Grid>

                <Separator Grid.Row="1" Background="{StaticResource BackgroundTertiary}" Margin="0,0,0,20"/>

                <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="0,10,0,0">
                    <!-- Main Tab -->
                    <TabItem Header="Main" Foreground="{StaticResource TextPrimary}" Background="{StaticResource BackgroundTertiary}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="250"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Species ID" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBox x:Name="SpeciesTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Height="30"/>

                                    <TextBlock Text="Nickname" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBox x:Name="NicknameTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Height="30"/>

                                    <TextBlock Text="Level" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBox x:Name="LevelTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Height="30"/>
                                </Grid>
                                <Button Content="Save Changes" Width="150" HorizontalAlignment="Right" Margin="0,10,0,0" Height="35" Click="ApplyChanges_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    
                    <!-- Analyzer Tab -->
                    <TabItem Header="Legality Analyzer" Foreground="{StaticResource TextPrimary}" Background="{StaticResource BackgroundTertiary}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                            <Border Background="{StaticResource BackgroundTertiary}" CornerRadius="8" Padding="15">
                                <TextBlock x:Name="LegalityReportBlock" Text="Load a Pokémon to see legality." TextWrapping="Wrap" FontFamily="Consolas" Foreground="{StaticResource TextPrimary}"/>
                            </Border>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
