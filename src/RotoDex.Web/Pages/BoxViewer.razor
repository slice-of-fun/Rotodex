@page "/boxes"
@using Roto.Core
@using RotoDex.Web.Services
@inject SaveStateService SaveState
@inject NavigationManager Nav

<PageTitle>PC Box Viewer — RotoDex</PageTitle>

@if (SaveState.LoadedSav == null)
{
    <div class="glass-card" style="text-align: center; padding: 60px 20px;">
        <h2 style="color: var(--text-secondary);">No Save Loaded</h2>
        <p style="color: var(--text-secondary);">Please load a save file on the <a href="/">Inspector</a> page first.</p>
    </div>
}
else
{
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; flex-wrap: wrap; gap: 10px;">
        <h2 style="margin: 0;">PC Box Viewer</h2>
        <div style="display: flex; align-items: center; gap: 12px;">
            <button class="btn btn-primary" @onclick="PreviousBox" disabled="@(_currentBox == 0)">← Prev</button>
            <span style="font-weight: bold; font-size: 1.1rem; min-width: 100px; text-align: center;">
                @_boxName
            </span>
            <button class="btn btn-primary" @onclick="NextBox" disabled="@(_currentBox >= SaveState.LoadedSav!.BoxCount - 1)">Next →</button>
        </div>
    </div>

    <div class="glass-card">
        <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px;">
            @for (int i = 0; i < _slots.Length; i++)
            {
                var slot = _slots[i];
                var isEmpty = slot.Species == 0;
                <div style="@(isEmpty ? "background: rgba(255,255,255,0.03); border: 1px dashed rgba(255,255,255,0.1);" : "background: rgba(98,0,238,0.2); border: 1px solid rgba(98,0,238,0.5);") border-radius: 8px; padding: 8px; min-height: 70px; display: flex; flex-direction: column; align-items: center; justify-content: center; transition: all 0.2s;">
                    @if (!isEmpty)
                    {
                        <div style="font-size: 0.75rem; color: var(--text-secondary);">
                            #@slot.Species
                        </div>
                        <div style="font-size: 0.85rem; font-weight: 600; text-align: center;">
                            @((Species)slot.Species)
                        </div>
                        <div style="font-size: 0.7rem; color: var(--text-secondary); margin-top: 2px;">
                            Lv.@slot.CurrentLevel
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private int _currentBox = 0;
    private PKM[] _slots = Array.Empty<PKM>();
    private string _boxName = "";

    protected override void OnInitialized()
    {
        if (SaveState.LoadedSav != null)
            LoadBox();
    }

    private void LoadBox()
    {
        var sav = SaveState.LoadedSav;
        if (sav == null) return;
        _slots = sav.GetBoxData(_currentBox);
        _boxName = sav is IBoxDetailName bn
            ? bn.GetBoxName(_currentBox)
            : $"Box {_currentBox + 1}";
    }

    private void PreviousBox()
    {
        if (_currentBox > 0) { _currentBox--; LoadBox(); }
    }

    private void NextBox()
    {
        var sav = SaveState.LoadedSav;
        if (sav != null && _currentBox < sav.BoxCount - 1) { _currentBox++; LoadBox(); }
    }
}
